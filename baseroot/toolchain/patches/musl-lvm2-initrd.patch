-		return 0;
+	/* stdout (fd 1) */
+	if (!is_valid_fd(STDOUT_FILENO)) {
+		fd = open(_PATH_DEVNULL, O_WRONLY);
+		if (fd < 0) {
+			if (err)
+				perror("stdout open");
+			return 0;
+		}
+		if (fd != STDOUT_FILENO) {
+			dup2(fd, STDOUT_FILENO);
+			close(fd);
+		}
 	}
 
-	if (!is_valid_fd(STDERR_FILENO) &&
-	    !(stderr = fopen(_PATH_DEVNULL, "w"))) {
-		printf("stderr stream open: %s\n",
-		       strerror(errno));
-		return 0;
+	/* stderr (fd 2) */
+	if (!is_valid_fd(STDERR_FILENO)) {
+		fd = open(_PATH_DEVNULL, O_WRONLY);
+		if (fd < 0) {
+			printf("stderr open: %s\n", strerror(errno));
+			return 0;
+		}
+		if (fd != STDERR_FILENO) {
+			dup2(fd, STDERR_FILENO);
+			close(fd);
+		}
 	}
 
 	return 1;
